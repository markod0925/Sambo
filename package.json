{
  "name": "sambo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "test": "npm run build && node --test test/**/*.test.js",
    "test:cli:midi-scrub": "npm run build && node scripts/midi-scrub-cli-e2e.mjs",
    "check": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "start": "npm run build && node scripts/serve.mjs",
    "play:cli": "npm run build && node scripts/play-cli.mjs"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@spotify/basic-pitch": "^1.0.1",
    "@tensorflow/tfjs": "^3.21.0",
    "@tonejs/midi": "^2.0.28",
    "audio-decode": "^2.2.3",
    "busboy": "^1.6.0",
    "phaser": "^3.90.0"
  }
}
