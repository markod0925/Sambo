{
  "name": "sambo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc -p tsconfig.json",
    "test": "npm run build && node --test test/**/*.test.js",
    "check": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
